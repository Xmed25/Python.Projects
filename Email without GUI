person={} 

def pre(func):
    def wrapper(*arg,**kwargs):
        print("SIGN UP\n")
        result=func(*arg,**kwargs)
        print("Thank You for Signing up")
        return result
    return wrapper

def confirm(password):
        conf=input("Confirm Password: ")
        if conf==password:
            print("Password Confirmed !")
            return True
        else:
            print("confirm password does not match")
            return False 
            
class Signup:
    def __init__(self,user,password,email,nickname,dob,gender):
        self.user=user
        self.__password=password
        self.email=email
        self.nickname=nickname
        self.dob=dob
        self.gender=gender
    
    def displaying(self):
        print(f"""
        USER ID :{self.user}
        Password:{len(self.__password)*'*'}
        Email:{len(self.email[:5])*'*'+self.email[5:-1]}
        Nickname:{self.nickname}
              """)
